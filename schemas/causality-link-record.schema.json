{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/causality-link-record.schema.json",
  "title": "Causality Link Record",
  "description": "A minimal record for expressing an evidence-backed causal relationship between a cause event and an effect event.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "causality_link_id",
    "created_at",
    "cause_event",
    "effect_event",
    "relation_type",
    "evidence_refs",
    "causality_confidence",
    "review_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "causality_link_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer_type",
        "issuer_id"
      ],
      "properties": {
        "issuer_type": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system",
            "organization",
            "other"
          ]
        },
        "issuer_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cause_event": {
      "$ref": "#/$defs/event_reference"
    },
    "effect_event": {
      "$ref": "#/$defs/event_reference"
    },
    "relation_type": {
      "type": "string",
      "enum": [
        "direct_cause",
        "contributing_cause",
        "enabling_condition",
        "transformation",
        "delegation",
        "influence",
        "temporal_precedence",
        "structural_similarity",
        "independent_convergence",
        "unknown"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_reference"
      }
    },
    "causality_confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "basis"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "basis": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "unreviewed",
        "machine_assessed",
        "human_review_required",
        "human_confirmed",
        "human_rejected",
        "disputed"
      ]
    },
    "human_review": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "decision",
        "reviewed_at"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "confirmed",
            "rejected",
            "inconclusive"
          ]
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "event_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "occurred_at"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "enum": [
            "question",
            "trace",
            "delegation",
            "agent_action",
            "transformation",
            "artifact",
            "audit",
            "contribution",
            "allocation",
            "other"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "evidence_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "ref"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "trace_record",
            "action_receipt",
            "handoff_record",
            "artifact",
            "audit_record",
            "external_source",
            "human_testimony",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
