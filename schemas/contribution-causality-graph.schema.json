{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/contribution-causality-graph.schema.json",
  "title": "Contribution Causality Graph",
  "description": "A machine-readable graph for representing evidence-backed causal contribution relationships across humans, agents, systems, tools, actions, transformations, and artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contribution_graph_id",
    "created_at",
    "artifact_refs",
    "contributors",
    "contribution_nodes",
    "contribution_edges",
    "graph_policy",
    "graph_confidence",
    "review_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.4"
    },
    "contribution_graph_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "contributors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contributor"
      }
    },
    "contribution_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contribution_node"
      }
    },
    "contribution_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contribution_edge"
      }
    },
    "graph_policy": {
      "$ref": "#/$defs/graph_policy"
    },
    "graph_confidence": {
      "$ref": "#/$defs/confidence_assessment"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "unreviewed",
        "machine_assessed",
        "human_review_required",
        "human_confirmed",
        "human_rejected",
        "disputed"
      ]
    },
    "human_review": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "decision",
        "reviewed_at"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "confirmed",
            "rejected",
            "inconclusive"
          ]
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "graph_summary": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "ref"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "document",
            "code",
            "dataset",
            "image",
            "audio",
            "video",
            "model",
            "schema",
            "configuration",
            "decision_record",
            "composite",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contributor_id",
        "contributor_type",
        "role"
      ],
      "properties": {
        "contributor_id": {
          "type": "string",
          "minLength": 1
        },
        "contributor_type": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "sub_agent",
            "system",
            "tool",
            "organization",
            "other"
          ]
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "identity_ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "contribution_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "contributor_id",
        "contribution_type",
        "contribution_scope",
        "causal_role",
        "materiality",
        "evidence_refs",
        "node_confidence"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "contributor_id": {
          "type": "string",
          "minLength": 1
        },
        "contribution_type": {
          "type": "string",
          "enum": [
            "origin_question",
            "trace_creation",
            "analysis",
            "generation",
            "transformation",
            "selection",
            "editing",
            "assembly",
            "orchestration",
            "tool_execution",
            "verification",
            "annotation",
            "rejection",
            "context_provision",
            "other"
          ]
        },
        "action_binding_ref": {
          "type": "string",
          "minLength": 1
        },
        "causality_link_ref": {
          "type": "string",
          "minLength": 1
        },
        "delegation_chain_ref": {
          "type": "string",
          "minLength": 1
        },
        "contribution_scope": {
          "$ref": "#/$defs/contribution_scope"
        },
        "causal_role": {
          "type": "string",
          "enum": [
            "root_origin",
            "enabling",
            "direct",
            "contributing",
            "transformative",
            "selective",
            "corrective",
            "verification",
            "orchestration",
            "contextual",
            "undetermined"
          ]
        },
        "materiality": {
          "type": "string",
          "enum": [
            "critical",
            "major",
            "moderate",
            "minor",
            "undetermined"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_reference"
          }
        },
        "node_confidence": {
          "$ref": "#/$defs/confidence_assessment"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "contribution_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "from_node_id",
        "to_node_id",
        "relation_type",
        "evidence_refs",
        "edge_confidence"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "from_node_id": {
          "type": "string",
          "minLength": 1
        },
        "to_node_id": {
          "type": "string",
          "minLength": 1
        },
        "relation_type": {
          "type": "string",
          "enum": [
            "derived_from",
            "enabled",
            "influenced",
            "transformed_into",
            "selected_into",
            "edited_into",
            "assembled_with",
            "verified_by",
            "constrained_by",
            "depends_on",
            "superseded_by",
            "other"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_reference"
          }
        },
        "edge_confidence": {
          "$ref": "#/$defs/confidence_assessment"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "contribution_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_type"
      ],
      "properties": {
        "scope_type": {
          "type": "string",
          "enum": [
            "whole_artifact",
            "section",
            "file",
            "json_pointer",
            "line_range",
            "byte_range",
            "time_range",
            "upstream_context",
            "custom"
          ]
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string"
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "line",
            "byte",
            "second",
            "millisecond",
            "page",
            "character",
            "custom"
          ]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "evidence_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "ref"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "trace_record",
            "causality_link",
            "delegation_record",
            "action_binding",
            "action_receipt",
            "transformation_log",
            "artifact_diff",
            "version_control_commit",
            "execution_log",
            "audit_record",
            "human_testimony",
            "external_source",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "confidence_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "basis"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "basis": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "graph_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acyclic_expected",
        "multiple_roots_allowed",
        "multiple_parents_allowed"
      ],
      "properties": {
        "acyclic_expected": {
          "type": "boolean"
        },
        "multiple_roots_allowed": {
          "type": "boolean"
        },
        "multiple_parents_allowed": {
          "type": "boolean"
        }
      }
    }
  }
}
