{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/delegation-causality-chain.schema.json",
  "title": "Delegation Causality Chain",
  "description": "A machine-readable record for tracing delegation lineage across humans, agents, systems, and tools.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "delegation_chain_id",
    "created_at",
    "root_intent",
    "participants",
    "delegation_steps",
    "chain_status",
    "review_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "delegation_chain_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "root_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent_id",
        "originator_id",
        "summary"
      ],
      "properties": {
        "intent_id": {
          "type": "string",
          "minLength": 1
        },
        "originator_id": {
          "type": "string",
          "minLength": 1
        },
        "question_ref": {
          "type": "string",
          "minLength": 1
        },
        "trace_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "participants": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/participant"
      }
    },
    "delegation_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/delegation_step"
      }
    },
    "causality_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/causality_link_reference"
      }
    },
    "chain_status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "partially_completed",
        "blocked",
        "cancelled",
        "disputed"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "unreviewed",
        "machine_assessed",
        "human_review_required",
        "human_confirmed",
        "human_rejected",
        "disputed"
      ]
    },
    "human_review": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "decision",
        "reviewed_at"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "confirmed",
            "rejected",
            "inconclusive"
          ]
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_id",
        "participant_type"
      ],
      "properties": {
        "participant_id": {
          "type": "string",
          "minLength": 1
        },
        "participant_type": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "sub_agent",
            "system",
            "tool",
            "organization",
            "other"
          ]
        },
        "role": {
          "type": "string"
        },
        "system_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "delegation_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "sequence",
        "delegator_id",
        "delegatee_id",
        "delegation_type",
        "delegated_task",
        "authority_scope",
        "constraint_policy",
        "status",
        "occurred_at"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "delegator_id": {
          "type": "string",
          "minLength": 1
        },
        "delegatee_id": {
          "type": "string",
          "minLength": 1
        },
        "delegation_type": {
          "type": "string",
          "enum": [
            "human_to_agent",
            "agent_to_agent",
            "agent_to_sub_agent",
            "agent_to_tool",
            "system_to_agent",
            "handoff",
            "result_return",
            "other"
          ]
        },
        "delegated_task": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "task_id",
            "summary"
          ],
          "properties": {
            "task_id": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "input_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "expected_output_type": {
              "type": "string"
            }
          }
        },
        "authority_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_actions",
            "prohibited_actions",
            "redelegation_allowed"
          ],
          "properties": {
            "allowed_actions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "prohibited_actions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "redelegation_allowed": {
              "type": "boolean"
            },
            "max_delegation_depth": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          }
        },
        "constraint_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "inheritance_mode"
          ],
          "properties": {
            "inheritance_mode": {
              "type": "string",
              "enum": [
                "strict",
                "bounded_extension",
                "explicit_override",
                "none"
              ]
            },
            "inherited_constraints": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "added_constraints": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "removed_constraints": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "override_reason": {
              "type": "string"
            }
          }
        },
        "source_handoff_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_action_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "parent_step_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "delegated",
            "accepted",
            "in_progress",
            "completed",
            "failed",
            "blocked",
            "cancelled",
            "returned"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "result_ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "causality_link_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "causality_link_id",
        "ref"
      ],
      "properties": {
        "causality_link_id": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
