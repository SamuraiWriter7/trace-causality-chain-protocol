{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/unified-causality-lifecycle.schema.json",
  "title": "Unified Causality Lifecycle",
  "description": "A lifecycle-level record connecting questions, traces, causality records, delegation, actions, artifact bindings, contribution graphs, audits, royalty readiness, and human gates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle_id",
    "created_at",
    "root_context",
    "lifecycle_stages",
    "record_links",
    "audit_bridge",
    "royalty_readiness",
    "human_gate",
    "lifecycle_status",
    "review_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.5"
    },
    "lifecycle_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "root_context": {
      "$ref": "#/$defs/root_context"
    },
    "lifecycle_stages": {
      "type": "array",
      "minItems": 10,
      "items": {
        "$ref": "#/$defs/lifecycle_stage"
      }
    },
    "record_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/record_link"
      }
    },
    "audit_bridge": {
      "$ref": "#/$defs/audit_bridge"
    },
    "royalty_readiness": {
      "$ref": "#/$defs/royalty_readiness"
    },
    "human_gate": {
      "$ref": "#/$defs/human_gate"
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "completed_with_conditions",
        "blocked",
        "cancelled",
        "disputed"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "unreviewed",
        "machine_assessed",
        "human_review_required",
        "human_confirmed",
        "human_rejected",
        "disputed"
      ]
    },
    "human_review": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "decision",
        "reviewed_at"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "confirmed",
            "rejected",
            "inconclusive"
          ]
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "root_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "originator_id",
        "question_ref",
        "trace_ref",
        "intent_summary"
      ],
      "properties": {
        "originator_id": {
          "type": "string",
          "minLength": 1
        },
        "question_ref": {
          "type": "string",
          "minLength": 1
        },
        "trace_ref": {
          "type": "string",
          "minLength": 1
        },
        "intent_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "lifecycle_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "sequence",
        "stage_type",
        "status",
        "record_refs"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "stage_type": {
          "type": "string",
          "enum": [
            "question",
            "trace",
            "causality",
            "delegation",
            "action",
            "artifact_binding",
            "contribution_graph",
            "audit",
            "royalty_readiness",
            "human_gate"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "active",
            "completed",
            "completed_with_conditions",
            "blocked",
            "rejected",
            "disputed"
          ]
        },
        "record_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "actor_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "record_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_id",
        "from_stage_id",
        "to_stage_id",
        "relation_type",
        "evidence_refs",
        "link_confidence"
      ],
      "properties": {
        "link_id": {
          "type": "string",
          "minLength": 1
        },
        "from_stage_id": {
          "type": "string",
          "minLength": 1
        },
        "to_stage_id": {
          "type": "string",
          "minLength": 1
        },
        "relation_type": {
          "type": "string",
          "enum": [
            "initiated",
            "recorded_as",
            "causally_linked",
            "delegated_into",
            "executed_as",
            "bound_into",
            "aggregated_into",
            "audited_by",
            "assessed_for_readiness",
            "submitted_to_gate",
            "other"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "link_confidence": {
          "$ref": "#/$defs/confidence_assessment"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "audit_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_status",
        "audit_record_refs",
        "blocking_conditions",
        "proceed_allowed"
      ],
      "properties": {
        "audit_status": {
          "type": "string",
          "enum": [
            "not_requested",
            "pending",
            "passed",
            "passed_with_conditions",
            "failed",
            "disputed"
          ]
        },
        "audit_record_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "findings_summary": {
          "type": "string"
        },
        "blocking_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "proceed_allowed": {
          "type": "boolean"
        }
      }
    },
    "royalty_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_status",
        "contribution_graph_ref",
        "readiness_checks",
        "financial_allocation_executed"
      ],
      "properties": {
        "readiness_status": {
          "type": "string",
          "enum": [
            "not_assessed",
            "not_ready",
            "conditionally_ready",
            "ready",
            "blocked",
            "disputed"
          ]
        },
        "contribution_graph_ref": {
          "type": "string",
          "minLength": 1
        },
        "policy_ref": {
          "type": "string",
          "minLength": 1
        },
        "readiness_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/readiness_check"
          }
        },
        "financial_allocation_executed": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "readiness_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "check_type",
        "result",
        "evidence_refs"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "check_type": {
          "type": "string",
          "enum": [
            "provenance_complete",
            "contribution_graph_valid",
            "audit_passed",
            "rights_reviewed",
            "disputes_resolved",
            "human_approval_required",
            "custom"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "pending",
            "not_applicable"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "human_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_status",
        "reviewer_refs",
        "conditions"
      ],
      "properties": {
        "gate_status": {
          "type": "string",
          "enum": [
            "not_required",
            "pending",
            "approved",
            "approved_with_conditions",
            "rejected",
            "deferred",
            "disputed"
          ]
        },
        "reviewer_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decision_at": {
          "type": "string",
          "format": "date-time"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decision_basis": {
          "type": "string"
        }
      }
    },
    "confidence_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "basis"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "basis": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
